# ================================================================
# PromptVault — Environment Variables
# ================================================================
# 1. Copy this file:  cp .env.example .env.local
# 2. Fill in your values (never commit .env.local to git)
# ================================================================

# ── Supabase ──────────────────────────────────────────────────────
# Found at: supabase.com → Your Project → Settings → API

# Public anon key — safe to expose in browser
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key-here

# Service role key — SERVER SIDE ONLY, never expose to browser
# Used in API routes that need to bypass RLS (saves, profile)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── App ───────────────────────────────────────────────────────────
# Your deployed URL — used for OAuth redirects
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Future: Stripe ────────────────────────────────────────────────
# Uncomment when you add payments
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
